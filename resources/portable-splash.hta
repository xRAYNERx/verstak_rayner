<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<hta:application
  id="app"
  applicationname="Verstak Setup"
  border="dialog"
  borderstyle="normal"
  caption="yes"
  contextmenu="no"
  innerborder="no"
  maximizebutton="no"
  minimizebutton="no"
  navigable="no"
  scroll="no"
  selection="no"
  showintaskbar="yes"
  singleinstance="yes"
  sysmenu="no"
  version="1.0"
  windowstate="normal"
/>
<title>Verstak Setup</title>
<style>
  html, body {
    margin: 0;
    width: 460px;
    height: 250px;
    overflow: hidden;
    background: #2e3440;
    color: #eceff4;
    font: 500 13px/1.45 "Segoe UI", system-ui, sans-serif;
    user-select: none;
  }
  .wrap {
    height: 100%;
    box-sizing: border-box;
    padding: 28px 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .brand {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.24em;
    color: #81a1c1;
  }
  .title {
    font-size: 18px;
    font-weight: 600;
  }
  .status {
    font-size: 13px;
    color: #d8dee9;
    min-height: 20px;
  }
  .hint {
    font-size: 12px;
    color: #a7b0c0;
  }
  .track {
    height: 8px;
    border-radius: 999px;
    background: #3b4252;
    border: 1px solid #4c566a;
    overflow: hidden;
    position: relative;
  }
  .shimmer {
    position: absolute;
    top: 0;
    left: 0;
    width: 42%;
    height: 100%;
    background: linear-gradient(90deg, transparent, #88c0d0, #81a1c1, transparent);
    animation: slide 1.35s ease-in-out infinite;
  }
  .spinner-row {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 2px;
  }
  .spinner {
    width: 28px;
    height: 28px;
    border: 3px solid #4c566a;
    border-top-color: #88c0d0;
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes slide {
    0% { left: -45%; }
    100% { left: 105%; }
  }
</style>
<script type="text/javascript">
  var msgs = [
    'Распаковка файлов',
    'Подготовка мастера',
    'Запуск установщика'
  ];
  var msgIndex = 0;
  var statusEl;
  var dots = 0;

  function setStatus(text) {
    if (statusEl) statusEl.innerHTML = text;
  }

  function hasSetupProcess() {
    try {
      var wmi = GetObject('winmgmts:\\\\.\\root\\cimv2');
      var items = wmi.ExecQuery("SELECT Name FROM Win32_Process WHERE Name='VerstakSetup.exe'");
      var e = new Enumerator(items);
      for (; !e.atEnd(); e.moveNext()) return true;
    } catch (err) {}
    return false;
  }

  function tick() {
    dots = (dots + 1) % 4;
    var tail = '';
    for (var i = 0; i < dots; i++) tail += '.';
    setStatus(msgs[msgIndex] + tail);

    if (hasSetupProcess()) {
      window.close();
      return;
    }
  }

  function rotateMsg() {
    msgIndex = (msgIndex + 1) % msgs.length;
  }

  function init() {
    statusEl = document.getElementById('status');
    try {
      var shell = new ActiveXObject('WScript.Shell');
      shell.RegWrite('HKCU\\Software\\Microsoft\\Internet Explorer\\Main\\FeatureControl\\FEATURE_BROWSER_EMULATION\\mshta.exe', 11001, 'REG_DWORD');
    } catch (e) {}
    window.setInterval(tick, 350);
    window.setInterval(rotateMsg, 2200);
    tick();
  }

  window.onload = init;
</script>
</head>
<body>
  <div class="wrap">
    <div class="brand">VERSTAK</div>
    <div class="title">Подготовка установщика</div>
    <div class="spinner-row">
      <div class="spinner"></div>
      <div id="status" class="status">Распаковка файлов</div>
    </div>
    <div class="track"><div class="shimmer"></div></div>
    <div class="hint">Обычно 10–20 секунд. Не закрывайте это окно.</div>
  </div>
</body>
</html>